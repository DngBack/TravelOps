# OpenAI (required for agent)
OPENAI_API_KEY=sk-proj-...

# Langfuse (optional; for trace observability)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# App (optional)
TRAVELOPS_AGENT_VERSION=0.1.0
TRAVELOPS_ENV=staging
# Use real APIs (1/true) or stub only (0/false). Default: 1
TRAVELOPS_USE_REAL_API=1

# Mode: instant (fast) | thinking (reasoning, auto gpt-5-nano). Default: instant
TRAVELOPS_MODE=instant
# Override model per mode (optional)
# TRAVELOPS_MODEL_INSTANT=gpt-4o-mini
# TRAVELOPS_MODEL_THINKING=gpt-5-nano

# Logging: level (DEBUG|INFO|WARNING|ERROR), file path. Default: INFO, logs/travelops.log
TRAVELOPS_LOG_LEVEL=INFO
TRAVELOPS_LOG_FILE=logs/travelops.log

# Amadeus (optional; for real hotel list + flight offers with prices)
# Get free key: https://developers.amadeus.com/
AMADEUS_CLIENT_ID=...
AMADEUS_CLIENT_SECRET=...

# Alternatives to Amadeus (use one or both):
# HotelsAPI.com — hotels by city (500 req/month free): https://hotels-api.com/register.php
HOTELS_API_KEY=...
# AviationStack — flight routes only, no prices (Basic plan for routes): https://aviationstack.com/
AVIATIONSTACK_ACCESS_KEY=...

# Web search: DuckDuckGo only (no key). Requires duckduckgo-search (in dependencies).
